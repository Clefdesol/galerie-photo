---
import Layout from '../layouts/Layout.astro';
import { readdir, readFile, stat } from 'fs/promises';
import path from 'path';

const CONTENT_DIR = path.join(process.cwd(), 'src/content/evenements');

async function lireEvenements(dir) {
  const entries = (await readdir(dir)).filter(d => !d.startsWith('.'));
  const evenements = [];

  for (const entry of entries) {
    const fullPath = path.join(dir, entry);
    const s = await stat(fullPath);
    if (!s.isDirectory()) continue;

    const jsonPath = path.join(fullPath, '_index.json');
    try {
      const contenu = await readFile(jsonPath, 'utf-8');
      const data = JSON.parse(contenu);
      const slugRelatif = fullPath.replace(CONTENT_DIR + '/', '');
      evenements.push({ ...data, slug: slugRelatif });
    } catch {
      continue;
    }
  }

  return evenements.sort((a, b) => new Date(b.date) - new Date(a.date));
}

const evenements = await lireEvenements(CONTENT_DIR);
---

<Layout title="Accueil">
  <div class="max-w-6xl mx-auto px-8 py-12">

    <!-- Titre -->
    <div class="mb-10 border-b border-zinc-800 pb-10">
      <p class="text-xs text-amber-400 tracking-widest uppercase mb-3">Collection privée</p>
      <h1 class="text-5xl font-light text-zinc-100 tracking-tight">Mes Souvenirs</h1>
      <p class="text-zinc-500 mt-4 font-light">{evenements.length} événement{evenements.length > 1 ? 's' : ''}</p>
    </div>

    <!-- Barre de recherche -->
    <div class="mb-10">
      <input
        id="recherche"
        type="text"
        placeholder="Rechercher un événement, un mot-clé..."
        style="width:100%; padding: 12px 16px; background: #18181b; border: 1px solid #3f3f46; color: #e4e4e7; font-size: 0.9rem; letter-spacing: 0.05em; outline: none;"
        autocomplete="off"
      />
      <p id="recherche-info" class="text-zinc-600 text-xs mt-2 tracking-wide"></p>
    </div>

    <!-- Résultats de recherche -->
    <div id="resultats" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mb-8" style="display:none;"></div>

    <!-- Grille événements -->
    <div id="grille-evenements" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {evenements.map(ev => (
        <a href={`/evenements/${ev.slug}`} class="group block evenement-card"
          data-titre={ev.titre}
          data-tags={ev.photos ? ev.photos.flatMap(p => p.tags).join(' ') : ''}
          data-description={ev.description || ''}
        >
          <div class="overflow-hidden mb-4 relative" style="aspect-ratio: 1/1; background: #18181b;">
            {ev.couverture ? (
              <img
                src={`/evenements/${ev.slug}/${ev.couverture}`}
                alt={ev.titre}
                style="width: 100%; height: 100%; object-fit: contain; display: block;"
              />
            ) : ev.videos && ev.videos.length > 0 ? (
              <img
                src={`https://img.youtube.com/vi/${ev.videos[0].youtubeId}/hqdefault.jpg`}
                alt={ev.titre}
                style="width: 100%; height: 100%; object-fit: cover; display: block;"
              />
            ) : (
              <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">
                <span style="color:#71717a;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;">
                  {ev.type === 'categorie' ? '📁 ' + ev.sousEvenements?.length + ' événements' : 'Aucun média'}
                </span>
              </div>
            )}
          </div>
          <p class="text-xs text-amber-400 tracking-widest uppercase mb-1">
            {new Date(ev.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </p>
          <h2 class="text-lg font-light text-zinc-100 group-hover:text-amber-400 transition-colors duration-200">
            {ev.titre}
          </h2>
          <p class="text-sm text-zinc-600 mt-1">
            {ev.type === 'categorie'
              ? `${ev.sousEvenements?.length} sous-événement${ev.sousEvenements?.length > 1 ? 's' : ''}`
              : `${ev.photos?.length || 0} photo${ev.photos?.length > 1 ? 's' : ''}`
            }
          </p>
        </a>
      ))}
    </div>

  </div>
</Layout>

<script>
  const input = document.getElementById('recherche');
  const info = document.getElementById('recherche-info');
  const grille = document.getElementById('grille-evenements');
  const resultats = document.getElementById('resultats');

  input.addEventListener('input', async () => {
    const q = input.value.toLowerCase().trim();

    if (!q) {
      grille.style.display = 'grid';
      resultats.style.display = 'none';
      resultats.innerHTML = '';
      info.textContent = '';
      return;
    }

    // Recherche dans tous les niveaux via search.json
    const response = await fetch('/search.json');
    const tous = await response.json();

    const trouvés = tous.filter(ev =>
    
      ev.titre.toLowerCase().includes(q) ||
      (ev.tags || []).join(' ').toLowerCase().includes(q) ||
      (ev.description || '').toLowerCase().includes(q)
    );

    grille.style.display = 'none';
    resultats.style.display = trouvés.length ? 'grid' : 'none';

    resultats.innerHTML = trouvés.map(ev => `
      <a href="/evenements/${ev.slug}" class="group block">
        <div style="aspect-ratio:1/1;background:#18181b;margin-bottom:1rem;display:flex;align-items:center;justify-content:center;">
          <span style="color:#71717a;font-size:0.75rem;">${ev.titre}</span>
        </div>
        <p style="font-size:0.75rem;color:#c09050;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.25rem;">${ev.date}</p>
        <h2 style="font-size:1.125rem;font-weight:300;color:#e4e4e7;">${ev.titre}</h2>
        <p style="font-size:0.875rem;color:#52525b;margin-top:0.25rem;">${ev.nbPhotos} photo${ev.nbPhotos > 1 ? 's' : ''}</p>
      </a>
    `).join('');

    info.textContent = `${trouvés.length} résultat${trouvés.length > 1 ? 's' : ''} pour "${input.value}"`;
  });
</script>