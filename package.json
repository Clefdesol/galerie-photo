{
  "name": "galerie-photo",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "rm -rf .astro && astro dev",
    "build": "rm -rf dist && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "import": "node scripts/import-lightroom.mjs",
    "reorg": "node scripts/reorganiser.mjs",
    "deploy": "pkill -f 'astro dev' 2>/dev/null; sleep 1 && npm run reorg && npm run import && npm run build && npm run dev > /tmp/astro-dev.log 2>&1 &"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^7.0.6",
    "exifr": "^7.1.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0"
  }
}
